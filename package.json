{
  "name": "mars-colony-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:server": "tsx server/multiplayer.ts",
    "dev:multi": "concurrently -n vite,ws -c cyan,magenta \"vite --host 127.0.0.1\" \"tsx server/multiplayer.ts\"",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:audit:strict": "node scripts/i18n-audit.mjs --strict",
    "i18n:audit:update": "node scripts/i18n-audit.mjs --update-baseline",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "three": "^0.184.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
